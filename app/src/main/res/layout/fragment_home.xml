<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_kiosk_desktop"
    tools:context=".ui.HomeFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="18dp"
        android:paddingEnd="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home_title"
            android:textColor="#F8FAFC"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/home_subtitle"
            android:textColor="#B8C2D9"
            android:textSize="13sp" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_allowed_apps"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="8dp"
        android:paddingTop="88dp"
        android:paddingEnd="8dp"
        android:paddingBottom="28dp"
        android:clipToPadding="false" />

    <TextView
        android:id="@+id/text_empty_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:padding="24dp"
        android:text="@string/home_empty_state"
        android:textColor="#D2DBEE"
        android:textSize="16sp" />

    <!-- Hidden hotspot to open settings -->
    <View
        android:id="@+id/kiosk_exit_hotspot"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:layout_gravity="top|start"
        android:alpha="0.01"
        android:clickable="true"
        android:longClickable="true"
        android:focusable="true" />

    <View
        android:id="@+id/kiosk_corner_top_right"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:layout_gravity="top|end"
        android:alpha="0.01"
        android:clickable="true"
        android:focusable="true" />

    <View
        android:id="@+id/kiosk_corner_bottom_right"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:layout_gravity="bottom|end"
        android:alpha="0.01"
        android:clickable="true"
        android:focusable="true" />

    <View
        android:id="@+id/kiosk_corner_bottom_left"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:layout_gravity="bottom|start"
        android:alpha="0.01"
        android:clickable="true"
        android:focusable="true" />

</FrameLayout>
