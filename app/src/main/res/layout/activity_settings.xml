<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/device_status_label" />

        <TextView
            android:id="@+id/text_device_owner_state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/device_status_checking"
            android:textColor="#555555" />

        <Switch
            android:id="@+id/switch_single_app_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/single_app_mode_label" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/allowed_apps_label" />

        <TextView
            android:id="@+id/text_allowed_apps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/not_selected" />

        <Button
            android:id="@+id/button_select_apps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/select_apps" />

        <Switch
            android:id="@+id/switch_disable_status_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/disable_status_bar" />

        <Switch
            android:id="@+id/switch_disable_notifications"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/disable_notifications" />

        <Switch
            android:id="@+id/switch_hide_navigation_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/hide_navigation_bar" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/schedule_start" />

        <TextView
            android:id="@+id/text_start_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/not_selected" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/button_set_start_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/set_time" />

            <Button
                android:id="@+id/button_clear_start_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/clear_time" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/schedule_stop" />

        <TextView
            android:id="@+id/text_stop_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/not_selected" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/button_set_stop_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/set_time" />

            <Button
                android:id="@+id/button_clear_stop_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/clear_time" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/schedule_reboot" />

        <TextView
            android:id="@+id/text_reboot_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/not_selected" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/button_set_reboot_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/set_time" />

            <Button
                android:id="@+id/button_clear_reboot_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/clear_time" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/remote_policy_url" />

        <EditText
            android:id="@+id/edit_remote_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textUri" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/remote_token" />

        <EditText
            android:id="@+id/edit_remote_token"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword" />

        <Button
            android:id="@+id/button_save"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/save_and_apply" />

        <Button
            android:id="@+id/button_sync"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sync_now" />

        <Button
            android:id="@+id/button_set_pin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/set_or_change_pin" />

        <Button
            android:id="@+id/button_open_system_settings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/open_system_settings" />

        <Button
            android:id="@+id/button_exit_kiosk"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/exit_kiosk_mode" />
    </LinearLayout>
</ScrollView>
